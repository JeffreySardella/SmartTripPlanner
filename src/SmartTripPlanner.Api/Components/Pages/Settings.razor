@page "/settings"
@inject ICalendarService CalendarService
@inject OllamaManagementService OllamaManager
@inject IConfiguration Config
@inject IPersistenceService PersistenceService

<PageTitle>SmartTripPlanner | Settings</PageTitle>

<div class="min-h-screen bg-surface overflow-y-auto p-10">
    <header class="mb-12 flex justify-between items-end">
        <div>
            <h2 class="text-4xl font-black tracking-tighter text-on-surface mb-2">System Configuration</h2>
            <div class="flex gap-4">
                @if (_ollamaStatus?.IsRunning == true)
                {
                    <span class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-tertiary px-3 py-1 bg-tertiary/10 rounded-full">
                        <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span>
                        Ollama Connected
                    </span>
                }
                else
                {
                    <span class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-error px-3 py-1 bg-error/10 rounded-full">
                        <span class="w-2 h-2 rounded-full bg-error"></span>
                        Ollama Offline
                    </span>
                }
                @if (CalendarService.IsConfigured)
                {
                    <span class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-secondary px-3 py-1 bg-secondary/10 rounded-full">
                        <span class="w-2 h-2 rounded-full bg-secondary"></span>
                        Cal-Sync Active
                    </span>
                }
            </div>
        </div>
        <div class="text-right">
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-on-surface-variant mb-1">Local Processing Engine</p>
            <p class="text-lg font-mono text-primary">v0.1.0-alpha</p>
        </div>
    </header>

    <div class="grid grid-cols-12 gap-8">
        @* ── GPU / Hardware Status ── *@
        <section class="col-span-12 lg:col-span-4 bg-surface-container rounded-xl p-8 border border-outline-variant/5 hover:border-primary/20 transition-all group">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h3 class="text-lg font-bold tracking-tight">Hardware Status</h3>
                    <p class="text-xs text-on-surface-variant">
                        @(_selectedGpu?.Name ?? "Detecting GPU...")
                    </p>
                </div>
                <span class="material-symbols-outlined text-primary group-hover:rotate-12 transition-transform">memory</span>
            </div>

            @if (_selectedGpu is not null)
            {
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest mb-2">
                            <span>VRAM Usage</span>
                            <span class="text-secondary">@(_selectedGpu.VramUsagePercent)%</span>
                        </div>
                        <div class="h-3 bg-surface-container-highest rounded-full overflow-hidden p-[2px]">
                            <div class="h-full vram-gradient rounded-full transition-all duration-500"
                                 style="width: @(_selectedGpu.VramUsagePercent)%"></div>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 pt-2">
                        <div class="bg-surface-container-low p-4 rounded-lg">
                            <p class="text-[10px] font-bold uppercase text-on-surface-variant mb-1">Used</p>
                            <p class="text-xl font-black">@FormatMb(_selectedGpu.VramUsedMb)</p>
                        </div>
                        <div class="bg-surface-container-low p-4 rounded-lg">
                            <p class="text-[10px] font-bold uppercase text-on-surface-variant mb-1">Free</p>
                            <p class="text-xl font-black">@FormatMb(_selectedGpu.VramFreeMb)</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-on-surface-variant">
                        <span class="material-symbols-outlined text-sm">developer_board</span>
                        <span>@_selectedGpu.Backend — @FormatMb(_selectedGpu.VramTotalMb) total</span>
                    </div>
                </div>
            }
        </section>

        @* ── Model Selector ── *@
        <section class="col-span-12 lg:col-span-8 bg-surface-container rounded-xl p-8 border border-outline-variant/5">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-lg font-bold tracking-tight">Installed Models</h3>
                <button @onclick="LoadModels"
                        class="text-[10px] font-bold uppercase tracking-widest text-primary hover:underline transition-all flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">refresh</span>
                    Refresh
                </button>
            </div>
            @if (_models is not null && _models.Count > 0)
            {
                <div class="space-y-3">
                    @foreach (var model in _models)
                    {
                        var isActive = model.Name == _activeModel;
                        <div @onclick="() => SelectModel(model.Name)"
                             class="group relative flex items-center justify-between p-4 rounded-lg cursor-pointer transition-colors
                                    @(isActive ? "bg-surface-container-high border-l-4 border-tertiary" : "bg-surface-container-low border-l-4 border-transparent hover:bg-surface-container-highest")">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined @(isActive ? "text-tertiary" : "text-on-surface-variant")">
                                    @(isActive ? "model_training" : "auto_awesome")
                                </span>
                                <div>
                                    <p class="font-bold text-sm tracking-tight">@model.Name</p>
                                    <p class="text-[10px] text-on-surface-variant uppercase tracking-widest">
                                        @(model.Details?.Family ?? "LLM") — @(model.Details?.QuantizationLevel ?? "default")
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="px-2 py-0.5 bg-surface-container-lowest text-[10px] font-mono rounded text-on-surface-variant">
                                    @FormatBytes(model.Size)
                                </span>
                                <div class="w-5 h-5 rounded-full border-2 @(isActive ? "border-tertiary" : "border-outline") flex items-center justify-center transition-colors">
                                    @if (isActive)
                                    {
                                        <div class="w-2.5 h-2.5 rounded-full bg-tertiary"></div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-on-surface-variant text-sm italic">No models detected. Is Ollama running?</p>
            }
        </section>

        @* ── Benchmark ── *@
        <section class="col-span-12 lg:col-span-7 bg-surface-container rounded-xl overflow-hidden border border-outline-variant/5">
            <div class="p-8 pb-4">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-bold tracking-tight">Performance Benchmarks</h3>
                    <button @onclick="RunBenchmark"
                            disabled="@(_benchRunning || _benchSelected.Count == 0)"
                            class="bg-secondary text-on-secondary px-6 py-2 rounded-full text-xs font-black uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all disabled:opacity-30">
                        @(_benchRunning ? $"Testing {_benchProgress}/{_benchSelected.Count}..." : "Run Benchmark")
                    </button>
                </div>
                <p class="text-xs text-on-surface-variant mb-6">Select models to compare inference speeds on your hardware.</p>
                @if (_models is not null)
                {
                    <div class="flex gap-4 mb-8 flex-wrap">
                        @foreach (var model in _models)
                        {
                            <label class="flex items-center gap-2 cursor-pointer bg-surface-container-low px-3 py-2 rounded-lg border border-outline-variant/10">
                                <input type="checkbox" checked="@_benchSelected.Contains(model.Name)"
                                       @onchange="e => ToggleBenchModel(model.Name, (bool)(e.Value ?? false))"
                                       class="rounded border-none bg-surface-container-highest text-primary focus:ring-0" />
                                <span class="text-[10px] font-bold uppercase tracking-widest">@model.Name.Split(':').First()</span>
                            </label>
                        }
                    </div>
                }
            </div>
            @if (_benchResults.Count > 0)
            {
                <div class="px-8 pb-8">
                    <table class="w-full text-left text-sm">
                        <thead>
                            <tr class="text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant border-b border-outline-variant/10">
                                <th class="pb-3 px-2">Rank</th>
                                <th class="pb-3 px-2">Model</th>
                                <th class="pb-3 px-2">Speed (tok/s)</th>
                                <th class="pb-3 px-2">Time</th>
                                <th class="pb-3 px-2">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/5">
                            @{
                                var ranked = _benchResults.Where(r => r.Success).OrderByDescending(r => r.TokensPerSec)
                                    .Concat(_benchResults.Where(r => !r.Success)).ToList();
                                var rank = 0;
                            }
                            @foreach (var r in ranked)
                            {
                                rank++;
                                var isBest = rank == 1 && r.Success;
                                <tr class="@(isBest ? "bg-tertiary/5" : "")">
                                    <td class="py-4 px-2 font-bold">
                                        @if (r.Success)
                                        {
                                            <span class="@(isBest ? "text-tertiary" : "")">@rank.ToString("D2")</span>
                                        }
                                    </td>
                                    <td class="py-4 px-2 font-bold flex items-center gap-2">
                                        @r.Model
                                        @if (isBest)
                                        {
                                            <span class="text-[8px] bg-tertiary/20 text-tertiary px-1.5 py-0.5 rounded font-bold">FASTEST</span>
                                        }
                                    </td>
                                    <td class="py-4 px-2 font-mono @(isBest ? "text-tertiary" : "")">@(r.Success && r.TokensPerSec > 0 ? r.TokensPerSec.ToString("F1") : "—")</td>
                                    <td class="py-4 px-2 font-mono">@(r.Success ? $"{r.TimeSec}s" : "—")</td>
                                    <td class="py-4 px-2">
                                        @if (r.Success)
                                        {
                                            <span class="text-[10px] font-bold text-tertiary">PASS</span>
                                        }
                                        else
                                        {
                                            <span class="text-[10px] font-bold text-error" title="@r.Error">FAIL</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        @* ── Google Calendar ── *@
        <section class="col-span-12 lg:col-span-5 flex flex-col gap-8">
            <div class="bg-surface-container rounded-xl p-8 border border-outline-variant/5 flex-1 flex flex-col">
                <div class="flex justify-between items-center mb-6">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary">calendar_month</span>
                        </div>
                        <h3 class="text-lg font-bold tracking-tight">Calendar Sync</h3>
                    </div>
                    @if (CalendarService.IsConfigured)
                    {
                        <span class="flex items-center gap-1.5 text-[10px] font-bold uppercase text-tertiary">
                            <span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span>
                            Synced
                        </span>
                    }
                    else
                    {
                        <span class="flex items-center gap-1.5 text-[10px] font-bold uppercase text-outline">
                            <span class="w-1.5 h-1.5 rounded-full bg-outline"></span>
                            Not Configured
                        </span>
                    }
                </div>

                @if (!CalendarService.IsConfigured)
                {
                    <div class="bg-surface-container-low p-4 rounded-lg text-sm text-on-surface-variant">
                        Place <code class="text-primary bg-surface-container-highest px-1.5 py-0.5 rounded text-xs">client_secret.json</code> in the project root and restart.
                    </div>
                }
                else
                {
                    <div class="space-y-3 mb-8">
                        @if (_calendars is not null)
                        {
                            @foreach (var cal in _calendars)
                            {
                                var isSelected = cal.Id == _selectedCalendarId;
                                var dotColor = cal.IsPrimary ? "bg-primary shadow-[0_0_8px_rgba(163,166,255,0.4)]" : "bg-secondary shadow-[0_0_8px_rgba(254,126,79,0.4)]";
                                <div class="flex items-center justify-between p-3 bg-surface-container-low rounded-lg border border-outline-variant/5 hover:bg-surface-container-highest transition-colors">
                                    <div @onclick="() => SelectCalendar(cal.Id)" class="flex items-center gap-3 flex-1 cursor-pointer">
                                        <span class="w-3 h-3 rounded-sm @dotColor"></span>
                                        <span class="text-sm font-medium">@cal.Name</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-on-surface-variant text-lg cursor-pointer"
                                              @onclick="() => SelectCalendar(cal.Id)"
                                              style="@(isSelected ? "font-variation-settings: 'FILL' 1;" : "")">
                                            @(isSelected ? "check_circle" : "radio_button_unchecked")
                                        </span>
                                        @if (!cal.IsPrimary)
                                        {
                                            @if (_confirmDeleteId == cal.Id)
                                            {
                                                <button @onclick="() => ConfirmDeleteCalendar(cal.Id)"
                                                        class="text-[10px] font-bold text-error bg-error/10 px-2 py-1 rounded hover:bg-error/20 transition-colors">Yes, delete</button>
                                                <button @onclick="() => _confirmDeleteId = null"
                                                        class="text-[10px] font-bold text-outline px-2 py-1 rounded hover:bg-surface-container-highest transition-colors">Cancel</button>
                                            }
                                            else
                                            {
                                                <button @onclick="() => _confirmDeleteId = cal.Id"
                                                        class="material-symbols-outlined text-outline hover:text-error text-lg transition-colors"
                                                        title="Delete calendar">delete</button>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="mt-auto">
                        <div class="flex gap-2 mb-3">
                            <input @bind="_newCalendarName" @bind:event="oninput"
                                   class="flex-1 bg-surface-container-low border border-outline-variant/10 rounded-lg px-3 py-2 text-sm text-on-surface focus:ring-0 focus:border-primary placeholder:text-outline"
                                   placeholder="New calendar name..." />
                        </div>
                        <button @onclick="CreateCalendar"
                                disabled="@(string.IsNullOrWhiteSpace(_newCalendarName) || _creating)"
                                class="w-full border border-primary/30 text-primary py-3 rounded-full font-bold text-xs uppercase tracking-[0.2em] hover:bg-primary/5 transition-all flex items-center justify-center gap-2 disabled:opacity-30">
                            <span class="material-symbols-outlined text-sm">add</span>
                            @(_creating ? "Creating..." : "Create Calendar")
                        </button>
                        @if (_createSuccess is not null)
                        {
                            <p class="text-xs text-tertiary mt-2 text-center">@_createSuccess</p>
                        }
                    </div>
                }
            </div>
        </section>

        @* ── My Preferences ── *@
        <section class="col-span-12 bg-surface-container rounded-xl p-8 border border-outline-variant/5">
            <div class="flex justify-between items-center mb-6">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">tune</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold tracking-tight">My Preferences</h3>
                        <p class="text-xs text-on-surface-variant">Your travel preferences — learned from usage or set by you</p>
                    </div>
                </div>
            </div>

            @if (_preferences.Count > 0)
            {
                <div class="space-y-3 mb-8">
                    @foreach (var pref in _preferences)
                    {
                        <div class="flex items-center justify-between p-4 bg-surface-container-low rounded-lg border border-outline-variant/5">
                            <div class="flex items-center gap-4">
                                <div>
                                    <p class="text-sm font-bold tracking-tight capitalize">@pref.Key.Replace("_", " ")</p>
                                    @if (_editingPrefId == pref.Id)
                                    {
                                        <input @bind="_editPrefValue" @bind:event="oninput"
                                               class="mt-1 bg-surface-container border border-outline-variant/10 rounded px-2 py-1 text-sm text-on-surface focus:ring-0 focus:border-primary" />
                                    }
                                    else
                                    {
                                        <p class="text-sm text-on-surface-variant">@pref.Value</p>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full
                                       @(pref.Source == "user" ? "bg-primary/10 text-primary" : "bg-secondary/10 text-secondary")">
                                    @(pref.Source == "user" ? "Set by you" : "Learned")
                                </span>
                                @if (_editingPrefId == pref.Id)
                                {
                                    <button @onclick="() => SaveEditedPreference(pref)"
                                            class="material-symbols-outlined text-tertiary text-lg hover:scale-110 transition-transform">check</button>
                                    <button @onclick="() => _editingPrefId = null"
                                            class="material-symbols-outlined text-outline text-lg hover:scale-110 transition-transform">close</button>
                                }
                                else
                                {
                                    <button @onclick="() => { _editingPrefId = pref.Id; _editPrefValue = pref.Value; }"
                                            class="material-symbols-outlined text-on-surface-variant text-lg hover:text-primary transition-colors">edit</button>
                                    <button @onclick="() => DeletePreference(pref.Key)"
                                            class="material-symbols-outlined text-on-surface-variant text-lg hover:text-error transition-colors">delete</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-on-surface-variant italic mb-8">No preferences saved yet. The AI will learn your patterns over time, or you can add them manually below.</p>
            }

            <div class="flex gap-2">
                <select @bind="_newPrefKey"
                        class="bg-surface-container-low border border-outline-variant/10 rounded-lg px-3 py-2 text-sm text-on-surface focus:ring-0 focus:border-primary">
                    <option value="">Select category...</option>
                    @foreach (var cat in PreferenceCategories)
                    {
                        <option value="@cat.Key">@cat.Label</option>
                    }
                </select>
                <input @bind="_newPrefValue" @bind:event="oninput"
                       class="flex-1 bg-surface-container-low border border-outline-variant/10 rounded-lg px-3 py-2 text-sm text-on-surface focus:ring-0 focus:border-primary placeholder:text-outline"
                       placeholder="@GetPlaceholder(_newPrefKey)" />
                <button @onclick="AddPreference"
                        disabled="@(string.IsNullOrWhiteSpace(_newPrefKey) || string.IsNullOrWhiteSpace(_newPrefValue))"
                        class="px-6 py-2 bg-primary text-on-primary rounded-lg font-bold text-xs uppercase tracking-widest hover:brightness-110 transition-all disabled:opacity-30">
                    Add
                </button>
            </div>
        </section>
    </div>
</div>

@code {
    private OllamaStatus? _ollamaStatus;
    private List<GpuInfo> _allGpus = [];
    private GpuInfo? _selectedGpu;
    private List<OllamaModel>? _models;
    private string _activeModel = "";

    private HashSet<string> _benchSelected = [];
    private List<BenchmarkResult> _benchResults = [];
    private bool _benchRunning;
    private int _benchProgress;

    private List<CalendarInfo>? _calendars;
    private string _selectedCalendarId = "primary";
    private string _newCalendarName = string.Empty;
    private bool _creating;
    private string? _createSuccess;
    private string? _confirmDeleteId;

    private List<UserPreference> _preferences = [];
    private string _newPrefKey = "";
    private string _newPrefValue = "";
    private int? _editingPrefId;
    private string _editPrefValue = "";

    protected override async Task OnInitializedAsync()
    {
        _activeModel = Config["Llm:Ollama:Model"] ?? "qwen3.5:35b-a3b";
        _selectedCalendarId = CalendarService.TargetCalendarId;

        var statusTask = OllamaManager.GetStatusAsync();
        var gpuTask = OllamaManager.GetAllGpusAsync();
        var modelsTask = OllamaManager.ListModelsAsync();
        Task<List<CalendarInfo>>? calTask = CalendarService.IsConfigured ? CalendarService.ListCalendarsAsync() : null;

        _ollamaStatus = await statusTask;
        _allGpus = await gpuTask;
        _selectedGpu = _allGpus.OrderByDescending(g => g.VramTotalMb).FirstOrDefault();
        _models = await modelsTask;
        if (calTask is not null) try { _calendars = await calTask; } catch { _calendars = []; }
        _preferences = await PersistenceService.GetPreferencesAsync();
        if (_models is not null) _benchSelected = _models.Select(m => m.Name).ToHashSet();
    }

    private async Task LoadModels()
    {
        _models = await OllamaManager.ListModelsAsync();
        _ollamaStatus = await OllamaManager.GetStatusAsync();
        _allGpus = await OllamaManager.GetAllGpusAsync();
        _selectedGpu = _allGpus.OrderByDescending(g => g.VramTotalMb).FirstOrDefault();
    }

    private void SelectModel(string name) => _activeModel = name;

    private void ToggleBenchModel(string model, bool selected)
    {
        if (selected) _benchSelected.Add(model); else _benchSelected.Remove(model);
    }

    private async Task RunBenchmark()
    {
        _benchRunning = true; _benchResults = []; _benchProgress = 0;
        StateHasChanged();

        const string prompt = "Plan a 1-day trip to San Francisco. I like seafood and parks. Relaxed pace. Give me 3 activities with times.";
        foreach (var model in _benchSelected)
        {
            _benchProgress++;
            StateHasChanged();
            _benchResults.Add(await OllamaManager.BenchmarkModelAsync(model, prompt));
            StateHasChanged();
        }
        _benchRunning = false;
        _allGpus = await OllamaManager.GetAllGpusAsync();
        _selectedGpu = _allGpus.OrderByDescending(g => g.VramTotalMb).FirstOrDefault();
    }

    private void SelectCalendar(string id) { _selectedCalendarId = id; CalendarService.TargetCalendarId = id; }

    private async Task ConfirmDeleteCalendar(string calendarId)
    {
        try
        {
            await CalendarService.DeleteCalendarAsync(calendarId);
            _calendars?.RemoveAll(c => c.Id == calendarId);
            if (_selectedCalendarId == calendarId)
                SelectCalendar("primary");
        }
        catch (Exception ex) { _createSuccess = $"Error: {ex.Message}"; }
        finally { _confirmDeleteId = null; }
    }

    private async Task CreateCalendar()
    {
        if (string.IsNullOrWhiteSpace(_newCalendarName)) return;
        _creating = true; _createSuccess = null; StateHasChanged();
        try
        {
            var created = await CalendarService.CreateCalendarAsync(_newCalendarName.Trim());
            _calendars?.Add(created);
            SelectCalendar(created.Id);
            _createSuccess = $"Created \"{created.Name}\"";
            _newCalendarName = string.Empty;
        }
        catch (Exception ex) { _createSuccess = $"Error: {ex.Message}"; }
        finally { _creating = false; }
    }

    private static string FormatBytes(long b) => b >= 1_000_000_000 ? $"{b / 1e9:F1} GB" : $"{b / 1e6:F0} MB";
    private static string FormatMb(int mb) => mb >= 1024 ? $"{mb / 1024.0:F1} GB" : $"{mb} MB";

    private static readonly (string Key, string Label, string Placeholder)[] PreferenceCategories =
    [
        ("pace", "Pace", "e.g. relaxed, moderate, packed"),
        ("dietary", "Dietary", "e.g. vegetarian, halal, gluten-free"),
        ("interests", "Interests", "e.g. food, culture, nightlife, outdoors"),
        ("morning_start", "Morning Preference", "e.g. early (before 8am), normal, late (after 10am)"),
        ("budget", "Budget", "e.g. budget, mid-range, luxury"),
        ("accessibility", "Accessibility", "e.g. wheelchair accessible, limited walking"),
        ("hotel_area", "Hotel Area Preference", "e.g. city center, near transit, quiet neighborhood"),
        ("avoid", "Things to Avoid", "e.g. tourist traps, crowded areas, malls"),
    ];

    private static string GetPlaceholder(string key)
    {
        if (string.IsNullOrEmpty(key)) return "Select a category first...";
        var cat = PreferenceCategories.FirstOrDefault(c => c.Key == key);
        return cat.Placeholder ?? "Enter your preference...";
    }

    private async Task AddPreference()
    {
        if (string.IsNullOrWhiteSpace(_newPrefKey) || string.IsNullOrWhiteSpace(_newPrefValue)) return;
        await PersistenceService.SavePreferenceAsync(_newPrefKey.Trim().ToLowerInvariant().Replace(" ", "_"), _newPrefValue.Trim(), "user");
        _preferences = await PersistenceService.GetPreferencesAsync();
        _newPrefKey = ""; _newPrefValue = "";
    }

    private async Task DeletePreference(string key)
    {
        await PersistenceService.DeletePreferenceAsync(key);
        _preferences = await PersistenceService.GetPreferencesAsync();
    }

    private async Task SaveEditedPreference(UserPreference pref)
    {
        if (string.IsNullOrWhiteSpace(_editPrefValue)) return;
        await PersistenceService.SavePreferenceAsync(pref.Key, _editPrefValue.Trim(), "user");
        _preferences = await PersistenceService.GetPreferencesAsync();
        _editingPrefId = null;
    }
}
