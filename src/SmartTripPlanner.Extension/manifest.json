{
  "manifest_version": 3,
  "name": "SmartTripPlanner Trip Saver",
  "version": "1.0.0",
  "description": "Save locations from any webpage to your SmartTripPlanner",
  "permissions": ["activeTab", "storage", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "parsers/structured.js",
        "parsers/google-maps.js",
        "parsers/yelp.js",
        "parsers/tripadvisor.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
